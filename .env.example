# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=dify_customer

# 应用配置
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=True
LOG_LEVEL=info

# 邮件配置
SMTP_SERVER=smtp.qq.com
SMTP_PORT=465
SMTP_EMAIL=your_email@qq.com
SMTP_AUTH_CODE=your_auth_code

# Redis配置（可选）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# JWT配置（可选）
JWT_SECRET_KEY=your_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
